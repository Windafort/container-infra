IMAGE_VERSION=2
RUNNER_IMAGE_VERSION=1

# Drone Server settings
DRONE_SERVER_HOST=drone.example.com
DRONE_SERVER_PROTO=http
DRONE_RPC_SECRET=super-duper-secret

# Gitea connection
DRONE_GITEA_SERVER=http://gitea:3000
DRONE_GITEA_CLIENT_ID=your-gitea-client-id
DRONE_GITEA_CLIENT_SECRET=your-gitea-client-secret

# GitHub connection (uncomment and configure if using GitHub instead of Gitea)
# DRONE_GITHUB_CLIENT_ID=your-github-client-id
# DRONE_GITHUB_CLIENT_SECRET=your-github-client-secret

# GitLab connection (uncomment and configure if using GitLab instead of Gitea)
# DRONE_GITLAB_SERVER=https://gitlab.com
# DRONE_GITLAB_CLIENT_ID=your-gitlab-client-id
# DRONE_GITLAB_CLIENT_SECRET=your-gitlab-client-secret

# Runner settings
DRONE_RUNNER_CAPACITY=2
DRONE_RUNNER_NAME=my-first-runner
